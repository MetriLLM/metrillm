# Optional — only needed for `--share` (upload results to public leaderboard)
# The Supabase anon key is public and uses Row Level Security (RLS).
LLMETER_SUPABASE_URL=https://your-project.supabase.co
LLMETER_SUPABASE_ANON_KEY=your-supabase-anon-key
LLMETER_PUBLIC_RESULT_BASE_URL=https://your-leaderboard-url.example.com
