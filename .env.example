# Optional — only needed for `--share` (upload results to public leaderboard)
# The Supabase anon key is public and uses Row Level Security (RLS).
METRILLM_SUPABASE_URL=https://your-project.supabase.co
METRILLM_SUPABASE_ANON_KEY=your-supabase-anon-key
METRILLM_PUBLIC_RESULT_BASE_URL=https://your-leaderboard-url.example.com

# Optional — PostHog telemetry (anonymous usage stats)
METRILLM_POSTHOG_KEY=your-posthog-project-api-key
