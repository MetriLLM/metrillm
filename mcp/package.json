    "@supabase/supabase-js": "^2.98.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "ollama": "^0.5.12",
    "ora": "^8.1.1",
    "posthog-node": "^5.26.0",
    "systeminformation": "^5.23.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
